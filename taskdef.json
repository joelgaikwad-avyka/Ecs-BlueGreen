{
  "family": "scorecard-service-task",
  "networkMode": "bridge",
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "scorecard-service",
      "image": "<+pipeline.variables.AWS_ACC_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com/joelpoc/repo:v1.0.<+pipeline.sequenceId",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}

